<script type="text/javascript" src="https://cdn.adt567.net/atag.js?as=1632487396" charset="UTF-8" async="true" defer></script>
<script data-cfasync="false" type="text/javascript">
  var freestar = freestar || {};
  freestar.queue = freestar.queue || [];
  freestar.config = freestar.config || {};
  freestar.config.disabledProducts = {
  sideWall: true
 }; 
  freestar.config.enabled_slots = [];
  freestar.initCallback = function () { 
    (freestar.config.enabled_slots.length === 0) 
      ? freestar.initCallbackCalled = false 
      : freestar.newAdSlots(freestar.config.enabled_slots) 
  }
</script>
<script>
(function () {
  const skinId = "neowin_1x1_skin";
  const delay = 2000;

  function adActuallyServed(container) {
    const iframe = container.querySelector("iframe");
    if (!iframe) return false;

    const rect = iframe.getBoundingClientRect();
    return rect.width > 1 && rect.height > 1;
  }

  function monitorAdRender() {
    const el = document.getElementById(skinId);
    if (!el) {
      console.warn("Skin container not found.");
      return;
    }

    const observer = new MutationObserver(() => {
      if (adActuallyServed(el)) {
        observer.disconnect();
        if (window.freestar?.deleteSidewall) {
          freestar.deleteSidewall("neowin_sidewall_right");
          freestar.deleteSidewall("neowin_sidewall_left");
          console.log("Ad served in 1x1 — sidewalls removed.");
        } else {
          console.warn("freestar not ready.");
        }
      }
    });

    observer.observe(el, {
      childList: true,
      subtree: true,
    });
  }

  setTimeout(monitorAdRender, delay);
})();
</script>
